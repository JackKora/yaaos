#!/usr/bin/env bash
# e2e CI: brings up the test stack (Postgres + fake-github + yaaos in mock
# mode), runs the Playwright suite against it, tears down. No external
# credentials required.
#
# Each spec drives its own preconditions via `/api/testing/reset` +
# `/api/testing/seed/...` (see `app/testing/e2e_setup/`). There is no
# batch-seeded fixture — the empty-DB onboarding spec depends on that.

set -euo pipefail

cd "$(dirname "$0")/.."

# Resolve repo root from script location, not `git rev-parse` — works even
# in environments without a .git directory (e.g. RWX's git/clone checkout).
REPO_ROOT="$(cd ../.. && pwd)"
COMPOSE_FILE="${REPO_ROOT}/docker/docker-compose.test.yml"

echo "==> docker compose up (test stack)"
# `--build` is load-bearing: without it, `up` reuses any cached image whose
# tag matches, even if local source has changed. We hit this exact trap
# during M05 close-out — a stale image from before the `domain/auth` →
# `domain/sessions` rename kept passing e2e while production was broken.
# Tradeoff: a clean run is slower (full rebuild). Worth it; the suite is
# small and runs end-to-end in under a minute.
docker compose -f "${COMPOSE_FILE}" up -d --build --wait

cleanup() {
  echo "==> docker compose down"
  docker compose -f "${COMPOSE_FILE}" down -v
}
trap cleanup EXIT

echo "==> playwright test"
pnpm exec playwright test
