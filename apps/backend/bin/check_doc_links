#!/usr/bin/env python3
"""Cross-doc link checker.

Walks every markdown file under `docs/`, `apps/*/docs/`, plus `CLAUDE.md`,
and checks that every relative `[text](path)` link resolves to a file that
exists. Fails on any broken link.

What it DOES check:
- Relative file paths in markdown links (e.g. `[X](../foo/bar.md)`).
- Paths with line suffixes (e.g. `[X](path/to.py:42)`) — strips the `:42`
  before checking.
- Anchors are stripped (`#section`) — only file existence is verified, not
  heading existence.

What it does NOT check:
- `http://` / `https://` / `mailto:` URLs.
- Anchor validity (would need to parse target headings).
- Broken images.

Cheap, no third-party deps, zero infrastructure. Run as part of
`apps/backend/bin/ci`.
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[3]  # apps/backend/bin/check_doc_links → repo root

# Anchor file paths under these dirs:
DOC_GLOBS = [
    "docs/**/*.md",
    "apps/*/docs/**/*.md",
    "CLAUDE.md",
]

# [text](target) — non-greedy text + target, where target doesn't contain ) or whitespace.
LINK_RE = re.compile(r"\[(?P<text>[^\]]*?)\]\((?P<target>[^)\s]+)\)")


def is_external(target: str) -> bool:
    return target.startswith(("http://", "https://", "mailto:", "tel:", "#"))


def strip_anchor_and_line(target: str) -> str:
    """`foo.md#bar` → `foo.md`; `foo.py:42` → `foo.py`."""
    if "#" in target:
        target = target.split("#", 1)[0]
    if ":" in target:
        # Only strip `:<digits>` line suffix — leave `:` alone elsewhere (e.g. anchors in non-markdown targets).
        head, _, tail = target.rpartition(":")
        if tail.isdigit():
            target = head
    return target


def main() -> int:
    broken: list[tuple[Path, int, str]] = []

    files: list[Path] = []
    for glob in DOC_GLOBS:
        files.extend(REPO_ROOT.glob(glob))
    files = sorted(set(files))

    for file in files:
        try:
            text = file.read_text()
        except UnicodeDecodeError:
            continue
        for i, line in enumerate(text.splitlines(), start=1):
            for m in LINK_RE.finditer(line):
                target = m.group("target")
                if is_external(target) or not target:
                    continue
                cleaned = strip_anchor_and_line(target)
                if not cleaned:
                    continue
                resolved = (file.parent / cleaned).resolve()
                if not resolved.exists():
                    broken.append((file.relative_to(REPO_ROOT), i, target))

    if broken:
        sys.stderr.write(f"\nBroken doc links ({len(broken)}):\n")
        for path, line, target in broken:
            sys.stderr.write(f"  {path}:{line}  →  {target}\n")
        return 1
    print(f"OK — {len(files)} markdown files, no broken links.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
