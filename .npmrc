# Put pnpm's content-addressable store inside the workspace so RWX task
# layers capture it. The default ~/.local/share/pnpm/store lives outside
# the workspace and doesn't travel across `use:`d tasks, leaving
# node_modules symlinks dangling. With this setting, downstream tasks
# that mount the pnpm-install layer see a self-contained store.
store-dir=.pnpm-store
